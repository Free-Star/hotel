.list {
  padding: 24rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.item {
  width: 48%;
  background: #fff;
  margin-top: 20rpx;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.item .thumb {
  width: 100%;
  height: 200rpx;
}

.item .title {
  font-size: 28rpx;
  padding: 8rpx 12rpx 0;
  color: #333;
}

.item .desc {
  font-size: 24rpx;
  padding: 0 12rpx 12rpx;
  color: #666;
}
